// artpage Prisma 스키마 — 멀티테넌트 플랫폼
// 자체 PostgreSQL (vibers_main) — arthyun + art-way 통합

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 전시 테이블
model exhibitions {
  id             Int       @id @default(autoincrement())
  site_slug      String    @default("arthyun")
  title          String
  subtitle       String?
  artist         String?
  category       String?
  categories     String[]  @default([])
  poster_url     String?
  description    String?
  start_date     String?
  end_date       String?
  is_active      Boolean   @default(true)
  is_visible     Boolean   @default(true)
  is_main_slider Boolean   @default(false)
  youtube_url    String?
  sort_order     Int       @default(0)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 보도자료 테이블
model media_releases {
  id             Int       @id @default(autoincrement())
  site_slug      String    @default("arthyun")
  title          String
  content        String?
  press_name     String?
  source         String?
  source_url     String?
  link_url       String?
  image_url      String?
  published_date String?
  published_at   DateTime?
  is_visible     Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 메인 배너 테이블
model main_banner {
  id          Int       @id @default(autoincrement())
  site_slug   String    @default("arthyun")
  title       String?
  image_url   String?
  link_url    String?
  is_active   Boolean   @default(true)
  sort_order  Int       @default(0)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 문의 테이블
model inquiries {
  id          Int       @id @default(autoincrement())
  site_slug   String    @default("arthyun")
  type        String    @default("general")
  name        String
  phone       String?
  email       String?
  content     String?
  status      String    @default("new")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 일별 통계 테이블
model daily_stats {
  id          Int       @id @default(autoincrement())
  site_slug   String    @default("arthyun")
  date        String
  count       Int       @default(0)
  visitors    Int       @default(0)
  created_at  DateTime  @default(now())

  @@unique([site_slug, date])
}

// 사이트 설정 테이블 — site_slug를 고유키로 사용
model site_settings {
  id              Int       @id @default(autoincrement())
  site_slug       String    @unique
  site_name       String?
  site_title      String?
  site_description String?
  template        String    @default("arthyun")
  og_description  String?
  og_image_url    String?
  domain          String?
  logo_url        String?
  footer_logo_url String?
  address         String?
  phone           String?
  email           String?
  instagram_url   String?
  blog_url        String?
  youtube_url     String?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt
}

// 포트폴리오 테이블
model Portfolio {
  id          String   @id @default(uuid()) @db.Uuid
  site_slug   String   @default("arthyun")
  title       String
  description String?
  image_url   String?
  category    String?
  is_featured Boolean  @default(false)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@index([site_slug])
}
